---
import type { GetStaticPaths } from 'astro'
import BlogLayout from '../../../layouts/BlogLayout.astro'
import BlogPostGrid from '../../../components/blog/BlogPostGrid.astro'
import { getAllTags, getPostsByTag, tagToSlug } from '../../../util/blog'
import { pathWithBase } from '../../../util/links'

export const getStaticPaths: GetStaticPaths = async () => {
  const tags = await getAllTags()
  return tags.map((tag) => ({
    params: { tag: tagToSlug(tag) },
    props: { tag },
  }))
}

const { tag } = Astro.props
const posts = await getPostsByTag(tag)
const allTags = await getAllTags()
---

<BlogLayout title={`Posts tagged "${tag}"`} description={`All blog posts tagged with "${tag}".`}>
  <div class="blog-index">
    <header class="blog-index-header">
      <a href={pathWithBase('/blog/')} class="back-link">&larr; All posts</a>
      <h1>Tag: {tag}</h1>
      <p>{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
    </header>

    <nav class="blog-tags-nav" aria-label="Filter by tag">
      <a href={pathWithBase('/blog/')} class="tag-filter">All</a>
      {allTags.map((t) => (
        <a
          href={pathWithBase(`/blog/tags/${tagToSlug(t)}/`)}
          class:list={['tag-filter', { active: t === tag }]}
        >{t}</a>
      ))}
    </nav>

    <BlogPostGrid posts={posts} />
  </div>
</BlogLayout>

<style>
  .blog-index {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .back-link {
    font-family: 'Figtree', sans-serif;
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .back-link:hover {
    color: #00cc5f;
  }

  .blog-index-header {
    margin-bottom: 2rem;
  }

  .blog-index-header h1 {
    font-family: 'Figtree', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--sl-color-white);
    margin: 0 0 0.5rem;
  }

  .blog-index-header p {
    font-family: 'Figtree', sans-serif;
    font-size: 1.125rem;
    color: var(--sl-color-gray-2);
    margin: 0;
  }

  .blog-tags-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .tag-filter {
    font-family: 'Figtree', sans-serif;
    font-size: 0.85rem;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.06);
    color: var(--sl-color-gray-2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .tag-filter:hover {
    background: rgba(0, 204, 95, 0.1);
    border-color: rgba(0, 204, 95, 0.3);
    color: #00cc5f;
  }

  .tag-filter.active {
    background: rgba(0, 204, 95, 0.15);
    border-color: rgba(0, 204, 95, 0.4);
    color: #00cc5f;
  }
</style>
