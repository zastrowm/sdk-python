---
/**
 * Horizontal auto-scrolling quote carousel.
 * Dev quotes and customer quotes displayed as individual cards
 * that scroll continuously across the page within a panel.
 */
import { getCollection, render } from 'astro:content'
import { Image } from 'astro:assets'

const testimonialEntries = await getCollection('testimonials')
const testimonials = await Promise.all(
  testimonialEntries
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (entry) => {
      const { Content } = await render(entry)
      return { ...entry.data, Content }
    })
)
---

<section class="quote-carousel-section" aria-label="Developer and customer testimonials">
  <div class="carousel-track-wrapper" role="region" aria-roledescription="carousel">
    <div class="carousel-track" id="quote-carousel-track">
      {/* Render cards twice for seamless infinite scroll */}
      {[...testimonials, ...testimonials].map((testimonial) => {
        const Content = testimonial.Content
        return (
          <div class="quote-card">
            <blockquote class="quote-text">
              <Content />
            </blockquote>
            <div class="quote-author">
              <div class="author-details">
                <span class="author-name">{testimonial.name}</span>
                {testimonial.title && <span class="author-title">{testimonial.title}</span>}
                {testimonial.link && <a href={testimonial.link} class="quote-read-more" target="_blank" rel="noopener">Read more &rarr;</a>}
              </div>
              {testimonial.logo && (
                <div class="author-logo">
                  <Image src={testimonial.logo} alt={testimonial.name} height={24} class="logo-light" />
                  <Image src={testimonial.dark_logo ?? testimonial.logo} alt={testimonial.name} height={24} class="logo-dark" />
                </div>
              )}
            </div>
          </div>
        )
      })}
    </div>
  </div>
</section>

<style>
  .quote-carousel-section {
    padding: 2rem 0;
    overflow: hidden;
    position: relative;
  }

  /* Fade edges */
  .quote-carousel-section::before,
  .quote-carousel-section::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }

  .quote-carousel-section::before {
    left: 0;
    background: linear-gradient(to right, var(--sl-color-bg), transparent);
  }

  .quote-carousel-section::after {
    right: 0;
    background: linear-gradient(to left, var(--sl-color-bg), transparent);
  }

  .carousel-track-wrapper {
    overflow: hidden;
    width: 100%;
  }

  .carousel-track {
    display: flex;
    gap: 1.25rem;
    animation: scroll-quotes 90s linear infinite;
    width: max-content;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll-quotes {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-track {
      animation: none;
      flex-wrap: wrap;
      width: 100%;
      justify-content: center;
      padding: 0 2rem;
    }

    /* Hide duplicated cards used for infinite scroll */
    .quote-card:nth-child(n + 15) {
      display: none;
    }
  }

  .quote-card {
    flex-shrink: 0;
    width: 380px;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
  }

  :global([data-theme='light']) .quote-card {
    background: rgba(0, 0, 0, 0.02);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .quote-text {
    font-family: 'Figtree', sans-serif;
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--sl-color-gray-2);
    margin: 0;
    padding: 0;
    border: none;
    font-style: italic;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .quote-text :global(p) {
    margin: 0;
  }

  .quote-text :global(p:first-of-type)::before { content: '\201C'; }
  .quote-text :global(p:last-of-type)::after { content: '\201D'; }

  .quote-text :global(a) {
    display: none;
  }

  .quote-author {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .author-details {
    display: flex;
    flex-direction: column;
  }

  .author-name {
    font-family: 'Figtree', sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    color: var(--sl-color-white);
  }

  .author-title {
    font-family: 'Figtree', sans-serif;
    font-size: 0.75rem;
    color: var(--sl-color-gray-4);
  }

  .quote-read-more {
    font-family: 'Figtree', sans-serif;
    font-size: 0.7rem;
    color: var(--strands-green, #00cc5f);
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.2s ease;
  }

  .quote-read-more:hover {
    opacity: 0.8;
  }

  .author-logo {
    flex-shrink: 0;
  }

  .author-logo img {
    height: 24px;
    width: auto;
    max-width: 100px;
    object-fit: contain;
    opacity: 0.6;
    filter: grayscale(100%);
  }

  :global([data-theme='dark']) .author-logo img {
    filter: grayscale(100%) brightness(1.5);
  }

  .author-logo .logo-dark { display: none; }
  :global([data-theme='dark']) .author-logo .logo-light { display: none; }
  :global([data-theme='dark']) .author-logo .logo-dark { display: block; }

  @media (max-width: 768px) {
    .quote-card {
      width: 300px;
      padding: 1rem 1.25rem;
    }
  }
</style>
