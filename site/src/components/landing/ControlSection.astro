---
/**
 * "See what's happening" section — observability and hook-based visibility.
 * Bridges from "Build your way" (capability) to "Deliver high quality outcomes" (intervention).
 */
import LangCodeBlock from './LangCodeBlock.astro'

const tracePy = `from strands import Agent
from strands.hooks import AfterToolCallEvent

def log_tool_calls(event: AfterToolCallEvent):
    """Log every tool call."""
    print(f"Tool: {event.tool_use['name']}")
    print(f"Result: {event.result['status']}")

agent = Agent(
    tools=[search_logs, query_database],
    hooks=[log_tool_calls],
    trace_attributes={
        "service": "ops-agent",
        "env": "production",
    },
)`

const traceTs = `import {
  Agent, AfterToolCallEvent,
} from '@strands-agents/sdk'

const agent = new Agent({
  tools: [searchLogs, queryDatabase],
  traceAttributes: {
    service: 'ops-agent',
    env: 'production',
  },
})

agent.addHook(AfterToolCallEvent, (event) => {
  console.log(\`Tool: \${event.toolUse.name}\`)
  console.log(\`Status: \${event.result.status}\`)
})`
---

<section class="control-section">
  <div class="control-inner">
    <h2 class="section-heading">Stay in control</h2>
    <p class="section-description">
      Monitor, modify, and debug with hooks. The agent loop traces every decision by default. Hooks let you intercept any step to log it, validate it, or redirect it.
    </p>
    <div class="control-code">
      <LangCodeBlock pythonCode={tracePy} pythonFilename="observable_agent.py" tsCode={traceTs} tsFilename="observable_agent.ts" />
    </div>
    <p class="section-annotation">
      Built-in observability.
    </p>
  </div>
</section>

<style>
  .control-section {
    padding: 5rem 2rem;
    display: flex;
    justify-content: center;
  }

  .control-inner {
    max-width: 800px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .section-heading {
    font-family: 'Figtree', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    color: var(--sl-color-white);
    text-align: center;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .section-description {
    font-family: 'Figtree', sans-serif;
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--sl-color-gray-2);
    text-align: center;
    max-width: 640px;
    margin: 0;
  }

  .control-code {
    width: 100%;
    margin-top: 0.5rem;
  }

  .section-annotation {
    font-family: 'Figtree', sans-serif;
    font-size: 0.9rem;
    color: var(--sl-color-gray-4);
    text-align: center;
    margin: 0;
  }

  @media (max-width: 768px) {
    .control-section {
      padding: 3rem 1.5rem;
    }
  }
</style>
