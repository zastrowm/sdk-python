---
/**
 * Labs + Evals bottom section — two cards linking to experimental org and eval SDK.
 */
import { pathWithBase } from '../../util/links'

const cards = [
  {
    title: 'Strands Labs',
    description: 'Experimental projects pushing the boundaries of what agents can do. AI Functions, Robots, and more.',
    href: pathWithBase('/docs/labs/'),
    cta: 'Explore Labs',
  },
  {
    title: 'Strands Evals',
    description: 'Test your agent against scenarios before shipping. Define cases, pick evaluators, run experiments.',
    href: pathWithBase('/docs/user-guide/evals-sdk/quickstart/'),
    cta: 'Get started with Evals',
  },
]
---

<section class="labs-evals-section">
  <div class="labs-evals-inner">
    {cards.map((card) => (
      <a href={card.href} class="le-card">
        <h3 class="le-title">{card.title}</h3>
        <p class="le-description">{card.description}</p>
        <span class="le-cta">{card.cta} &rarr;</span>
      </a>
    ))}
  </div>
</section>

<style>
  .labs-evals-section {
    padding: 2rem 2rem 4rem;
    display: flex;
    justify-content: center;
  }

  .labs-evals-inner {
    max-width: 900px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .le-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  :global([data-theme='light']) .le-card {
    background: rgba(0, 0, 0, 0.02);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .le-card:hover {
    border-color: rgba(0, 204, 95, 0.3);
    box-shadow: 0 0 24px rgba(0, 204, 95, 0.06);
  }

  .le-title {
    font-family: 'Figtree', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--sl-color-white);
    margin: 0;
  }

  .le-description {
    font-family: 'Figtree', sans-serif;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--sl-color-gray-3);
    margin: 0;
    flex: 1;
  }

  .le-cta {
    font-family: 'Figtree', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--strands-green);
  }

  @media (max-width: 768px) {
    .labs-evals-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
