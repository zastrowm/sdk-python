---
/**
 * Hero section: headline + subtext on left, code snippet on right.
 */
import LangCodeBlock from './LangCodeBlock.astro'
import { getStarCount } from '../../util/github'

interface Props {
  baseUrl: string
}

const { baseUrl } = Astro.props
const withBase = (path: string) => {
  const b = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl
  return b + path
}

const stars = await getStarCount()

const heroPython = `from strands import Agent, tool
from strands.hooks import BeforeToolCallEvent
from pathlib import Path

@tool
def save_report(title: str, content: str) -> str:
    """Save a research report to disk."""
    path = f"reports/{title}.md"
    Path(path).write_text(content)
    return f"Saved {path}"

def require_sources(event: BeforeToolCallEvent):
    name = event.tool_use["name"]
    inp = str(event.tool_use["input"])
    if name == "save_report" and "[source]" not in inp:
        event.cancel_tool = "Add source citations."

agent = Agent(
    tools=[save_report],
    hooks=[require_sources],
)
agent("Research AI agent frameworks")`

const heroTs = `import {
  Agent, tool, BeforeToolCallEvent
} from '@strands-agents/sdk'
import z from 'zod'
import { writeFileSync } from 'fs'

const saveReport = tool({
  name: 'save_report',
  description: 'Save a research report.',
  inputSchema: z.object({
    title: z.string(),
    content: z.string(),
  }),
  callback: ({ title, content }) => {
    writeFileSync(\`reports/\${title}.md\`, content)
    return \`Saved \${title}.md\`
  },
})

const agent = new Agent({ tools: [saveReport] })

agent.addHook(BeforeToolCallEvent, (event) => {
  const inp = String(event.toolUse.input)
  if (event.toolUse.name === 'save_report') {
    if (!inp.includes('[source]')) {
      event.cancel = 'Add source citations.'
    }
  }
})

await agent.invoke('Research AI agent frameworks')`
---

<section class="hero-section">
  <div class="hero-background"></div>
  <div class="hero-inner">
    <div class="hero-text">
      <h1 class="hero-title">
        The open source<br />
        <span class="hero-highlight">agent harness SDK.</span>
      </h1>
      <p class="hero-subtitle">
        Build an agent harness. Control it end-to-end.
      </p>
      <div class="hero-cta">
        <a href={withBase('/docs/user-guide/quickstart/overview/')} class="cta-button primary">Get Started</a>
        <a href="https://github.com/strands-agents/sdk-python" class="cta-button secondary">GitHub</a>
      </div>
      <div class="hero-install-group">
        <div class="hero-install" data-copy="pip install strands-agents">
          <code>pip install strands-agents</code>
          <button class="install-copy" aria-label="Copy install command">
            <svg class="copy-icon" width="14" height="14" viewBox="0 0 16 16" fill="none">
              <rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
              <path d="M3 10.5V3a1.5 1.5 0 0 1 1.5-1.5H11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            <svg class="check-icon" width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M3.5 8.5L6.5 11.5L12.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <div class="hero-install" data-copy="npm install @strands-agents/sdk">
          <code>npm install @strands-agents/sdk</code>
          <button class="install-copy" aria-label="Copy install command">
            <svg class="copy-icon" width="14" height="14" viewBox="0 0 16 16" fill="none">
              <rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
              <path d="M3 10.5V3a1.5 1.5 0 0 1 1.5-1.5H11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            <svg class="check-icon" width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M3.5 8.5L6.5 11.5L12.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
      <!-- TODO: Restore harness concept link once /docs/user-guide/concepts/what-is-an-agent-harness/ ships -->
      <p class="hero-social-proof">
        {stars} GitHub stars · Built from production systems inside Amazon
      </p>
    </div>
    <div class="hero-code">
      <LangCodeBlock
        pythonCode={heroPython}
        pythonFilename="research_agent.py"
        tsCode={heroTs}
        tsFilename="research_agent.ts"
      />
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 3rem 2rem;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(0, 204, 95, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(0, 255, 119, 0.08) 0%, transparent 50%);
    z-index: 0;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-title {
    font-family: 'Figtree', sans-serif;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.1;
    color: var(--sl-color-white);
    letter-spacing: -0.03em;
    margin: 0;
  }

  .hero-highlight {
    color: var(--strands-green);
  }

  .hero-subtitle {
    font-family: 'Figtree', sans-serif;
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--sl-color-gray-3);
    margin: 0;
    max-width: 480px;
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.75rem;
    font-family: 'Figtree', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .cta-button.primary {
    background: var(--strands-green);
    color: #0E0E0E;
  }
  .cta-button.primary:hover {
    background: var(--strands-green-bright);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(0, 204, 95, 0.3);
    color: #0E0E0E;
  }

  .cta-button.secondary {
    background: transparent;
    color: var(--sl-color-white);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  .cta-button.secondary:hover {
    border-color: var(--strands-green);
    color: var(--strands-green);
  }

  .hero-install-group {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .hero-install {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    transition: border-color 0.2s ease;
  }

  .hero-install:hover {
    border-color: rgba(255, 255, 255, 0.2);
  }

  :global([data-theme='light']) .hero-install {
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.1);
  }

  :global([data-theme='light']) .hero-install:hover {
    border-color: rgba(0, 0, 0, 0.2);
  }

  .hero-install code {
    font-family: ui-monospace, 'SF Mono', 'Cascadia Code', monospace;
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
  }

  :global([data-theme='light']) .hero-install code {
    color: var(--sl-color-gray-2);
  }

  .install-copy {
    background: none;
    border: none;
    color: var(--sl-color-gray-4);
    cursor: pointer;
    padding: 2px;
    display: flex;
    align-items: center;
    transition: color 0.2s ease;
  }

  .install-copy:hover {
    color: var(--sl-color-white);
  }

  .install-copy .check-icon { display: none; }
  .install-copy.copied .copy-icon { display: none; }
  .install-copy.copied .check-icon { display: block; }
  .install-copy.copied { color: var(--strands-green); }

  .hero-social-proof {
    font-family: 'Figtree', sans-serif;
    font-size: 0.85rem;
    color: var(--sl-color-gray-4);
    margin: 0.25rem 0 0;
  }

  .hero-code {
    min-width: 0;
  }

  @media (max-width: 768px) {
    .hero-section {
      min-height: auto;
      padding: 2rem 1.5rem;
    }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .hero-title {
      font-size: clamp(1.75rem, 8vw, 2.5rem);
    }
    .hero-subtitle {
      max-width: 100%;
    }
  }

  @media (max-width: 430px) {
    .hero-section {
      padding: 1.5rem 1rem;
    }
    .hero-inner {
      gap: 1.5rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll<HTMLElement>('.hero-install').forEach((install) => {
      const btn = install.querySelector<HTMLButtonElement>('.install-copy')
      if (!btn) return

      const text = install.dataset.copy || ''

      // Map install commands to language preference
      const lang = text.startsWith('pip') ? 'Python' : text.startsWith('npm') ? 'TypeScript' : null

      const copy = async () => {
        await navigator.clipboard.writeText(text)
        btn.classList.add('copied')
        setTimeout(() => btn.classList.remove('copied'), 2000)

        // Set global language preference to match the install command
        if (lang) {
          try {
            const key = 'starlight-synced-tabs__jarkqt'
            localStorage.setItem(key, lang)
            // Update header toggle if present
            document.querySelectorAll<HTMLElement>('language-toggle .lang-option').forEach((opt) => {
              opt.setAttribute('aria-checked', opt.dataset.lang === lang ? 'true' : 'false')
            })
          } catch (e) {
            if (typeof console !== 'undefined') console.debug('[HeroSection] localStorage error:', e);
          }
          // Notify LangCodeBlock components
          window.dispatchEvent(new CustomEvent('lang-preference-changed', { detail: { lang } }))
        }
      }

      btn.addEventListener('click', copy)
      install.addEventListener('click', (e) => {
        if (e.target !== btn && !btn.contains(e.target as Node)) copy()
      })
    })
  })
</script>
