---
/**
 * Standalone 100% stat callout section.
 * Extracted from the old SteeringSection proof subsection.
 */
import { pathWithBase } from '../../util/links'
---

<section class="stats-section">
  <div class="stats-inner">
    <div class="proof-stats">
      <div class="stat-primary">
        <span class="stat-number">100%</span>
        <span class="stat-label">agent accuracy with steering</span>
      </div>
      <div class="stat-comparison">
        Prompt-only agents scored <strong>82.5%</strong>.<br />
        Hard-coded workflows scored <strong>80.8%</strong>.<br />
        Agents with Strands steering handlers recovered from every mistake.
      </div>
    </div>
    <a href={pathWithBase('/blog/steering-accuracy-beats-prompts-workflows/')} class="proof-link">
      See the benchmark &rarr;
    </a>
  </div>
</section>

<style>
  .stats-section {
    padding: 3rem 2rem;
    display: flex;
    justify-content: center;
  }

  .stats-inner {
    max-width: 800px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .proof-stats {
    text-align: center;
    padding: 2.5rem 3rem;
    border-radius: 16px;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(0, 204, 95, 0.15) 0%, transparent 70%),
      rgba(0, 204, 95, 0.04);
    border: 1px solid rgba(0, 204, 95, 0.2);
    width: 100%;
  }

  :global([data-theme='light']) .proof-stats {
    background:
      radial-gradient(ellipse at 50% 0%, rgba(0, 204, 95, 0.1) 0%, transparent 70%),
      rgba(0, 204, 95, 0.03);
    border-color: rgba(0, 204, 95, 0.15);
  }

  .stat-primary {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 1rem;
  }

  .stat-number {
    font-family: 'Figtree', sans-serif;
    font-size: clamp(3rem, 8vw, 4.5rem);
    font-weight: 700;
    color: var(--strands-green);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    font-family: 'Figtree', sans-serif;
    font-size: 1.125rem;
    color: var(--sl-color-gray-3);
  }

  .stat-comparison {
    font-family: 'Figtree', sans-serif;
    font-size: 1rem;
    color: var(--sl-color-gray-4);
  }

  .stat-comparison strong {
    color: var(--sl-color-white);
    font-weight: 600;
  }

  .proof-link {
    font-family: 'Figtree', sans-serif;
    font-size: 0.95rem;
    color: var(--strands-green);
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.2s ease;
  }

  .proof-link:hover {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .stats-section {
      padding: 2rem 1.5rem;
    }
    .proof-stats {
      padding: 2rem 1.5rem;
    }
  }
</style>
